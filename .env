# ══════════════════════════════════════════════════════════════
#  GEO PRO – Variables de entorno
#  1. Copiá este archivo: cp .env.example .env
#  2. Completá los valores reales
#  3. NUNCA subas el archivo .env a GitHub
# ══════════════════════════════════════════════════════════════


# ── MERCADO PAGO ──────────────────────────────────────────────
# Obtenelo en: https://www.mercadopago.com.ar/developers/panel
# → Sección "Credenciales" → Access Token
# Usá TEST para probar sin cobrar dinero real.
# Usá PRODUCCIÓN cuando estés listo para cobrar de verdad.
MP_ACCESS_TOKEN=APP_USR-7822727344353366-030121-fe0eda7673abb6658cb58edd794987d3-212312489


# ── EMAIL (GMAIL) ─────────────────────────────────────────────
# GMAIL_USER: tu dirección de Gmail completa
# GMAIL_PASS: NO es tu contraseña de Gmail normal.
#             Es una "Contraseña de aplicación" de 16 caracteres.
#
# Cómo generarla (5 minutos, solo una vez):
#   1. Entrá a: https://myaccount.google.com/security
#   2. Activá la "Verificación en 2 pasos" si no la tenés
#   3. Buscá "Contraseñas de aplicaciones" en esa misma página
#   4. En "Seleccionar aplicación" elegí "Correo"
#   5. En "Seleccionar dispositivo" elegí "Otro" → escribí "Geo Pro"
#   6. Copiá los 16 caracteres que te genera y pegálos abajo
#
GMAIL_USER=geoprotandil@gmail.com
GMAIL_PASS=hdzb olse mwyh xruj


# ── SERVIDOR ──────────────────────────────────────────────────
# En desarrollo dejalo así.
# En producción cambialo por tu dominio real (ej: https://geopro.com.ar)
BASE_URL=http://localhost:3000
PORT=3000


# ══════════════════════════════════════════════════════════════
#  PRECIOS DE INSTALACIÓN (en pesos ARS, sin puntos ni comas)
#  Modificá estos valores para actualizar la web y los pagos.
#  Luego reiniciá el servidor con: npm start
# ══════════════════════════════════════════════════════════════

PRECIO_MOTO=110000
PRECIO_AUTO=120000
PRECIO_CAMION=150000


# ── ARANCEL MENSUAL DE SERVICIO ───────────────────────────────
# Sujeto a revisión por contexto macroeconómico.

# Valor estándar (motos, autos, camiones individuales)
PRECIO_MENSUAL=15000

# Valor para flotas (tarifa reducida por volumen)
PRECIO_MENSUAL_FLOTA=13500

# Mínimo de unidades para acceder a la tarifa de flota
FLOTA_MINIMO_UNIDADES=30
